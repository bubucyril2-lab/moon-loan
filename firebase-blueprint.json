{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "status": { "type": "string", "enum": ["pending", "active", "disabled"] },
        "profilePicture": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "age": { "type": "integer" },
        "transactionPin": { "type": "string" },
        "twoFactorEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role", "status"]
    },
    "Account": {
      "title": "Account",
      "description": "Bank account details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "accountNumber", "balance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "referenceId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "accountId", "userId", "type", "amount", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "type"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Support chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "senderId", "text", "isAdmin"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Loan application record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "purpose": { "type": "string" },
        "interestRate": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "repaying", "completed"] },
        "repaymentSchedule": { "type": "string" },
        "paidAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "status"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "Deposit request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethodId": { "type": "string" },
        "proofImage": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "status"]
    },
    "Beneficiary": {
      "title": "Beneficiary",
      "description": "Saved transfer recipient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "accountNumber": { "type": "string" },
        "bankName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "accountNumber"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "Public contact form submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "message"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Admin activity log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminId": { "type": "string" },
        "adminName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "adminId", "adminName", "action", "details"]
    },
    "PaymentMethod": {
      "title": "PaymentMethod",
      "description": "Available payment methods for deposits/loans",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["bank", "crypto"] },
        "name": { "type": "string" },
        "details": { "type": "string" },
        "instructions": { "type": "string" },
        "is_active": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "name", "details", "instructions", "is_active"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "bankName": { "type": "string" },
        "bankEmail": { "type": "string" },
        "bankPhone": { "type": "string" },
        "bankAddress": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "allowRegistration": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profile document" },
    "/accounts/{accountId}": { "schema": "Account", "description": "Bank account document" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Transaction record document" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "Notification document" },
    "/chat_messages/{chatId}": { "schema": "ChatMessage", "description": "Chat message document" },
    "/loans/{loanId}": { "schema": "Loan", "description": "Loan application document" },
    "/deposits/{depositId}": { "schema": "Deposit", "description": "Deposit request document" },
    "/beneficiaries/{beneficiaryId}": { "schema": "Beneficiary", "description": "Beneficiary document" },
    "/contact_messages/{messageId}": { "schema": "ContactMessage", "description": "Contact message document" },
    "/audit_logs/{logId}": { "schema": "AuditLog", "description": "Admin audit log document" },
    "/payment_methods/{methodId}": { "schema": "PaymentMethod", "description": "Payment method document" },
    "/settings/{settingId}": { "schema": "Settings", "description": "Global settings document" }
  }
}
