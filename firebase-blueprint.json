{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique user ID (matches Firebase Auth UID)" },
        "fullName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["admin", "customer"], "description": "User's role" },
        "status": { "type": "string", "enum": ["active", "pending", "disabled"], "description": "Account status" },
        "pin": { "type": "string", "description": "4-digit transaction PIN" },
        "profilePicture": { "type": "string", "format": "uri", "description": "URL to profile picture" },
        "twoFactorEnabled": { "type": "boolean", "description": "Whether 2FA is enabled" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["id", "fullName", "email", "role", "status"]
    },
    "Account": {
      "title": "Account",
      "description": "Bank account information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique account ID" },
        "userId": { "type": "string", "description": "ID of the user who owns this account" },
        "accountNumber": { "type": "string", "description": "Bank account number" },
        "balance": { "type": "number", "description": "Current account balance" },
        "status": { "type": "string", "enum": ["active", "disabled"], "description": "Account status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["id", "userId", "accountNumber", "balance", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique transaction ID" },
        "accountId": { "type": "string", "description": "ID of the account involved" },
        "userId": { "type": "string", "description": "ID of the user who performed the transaction" },
        "amount": { "type": "number", "description": "Transaction amount" },
        "type": { "type": "string", "enum": ["credit", "debit"], "description": "Transaction type" },
        "category": { "type": "string", "description": "Transaction category (e.g., Transfer, Deposit, Loan)" },
        "description": { "type": "string", "description": "Transaction description" },
        "status": { "type": "string", "enum": ["completed", "pending", "failed"], "description": "Transaction status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Transaction timestamp" }
      },
      "required": ["id", "accountId", "userId", "amount", "type", "category", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique notification ID" },
        "userId": { "type": "string", "description": "ID of the user to notify" },
        "title": { "type": "string", "description": "Notification title" },
        "message": { "type": "string", "description": "Notification message" },
        "type": { "type": "string", "enum": ["info", "success", "alert"], "description": "Notification type" },
        "isRead": { "type": "boolean", "description": "Whether the notification has been read" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Notification timestamp" }
      },
      "required": ["id", "userId", "title", "message", "type", "isRead"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Support chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique message ID" },
        "userId": { "type": "string", "description": "ID of the customer" },
        "senderId": { "type": "string", "description": "ID of the sender (customer or admin)" },
        "text": { "type": "string", "description": "Message content" },
        "isAdmin": { "type": "boolean", "description": "Whether the sender is an admin" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Message timestamp" }
      },
      "required": ["id", "userId", "senderId", "text", "isAdmin"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Loan application and status",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique loan ID" },
        "userId": { "type": "string", "description": "ID of the applicant" },
        "amount": { "type": "number", "description": "Loan amount" },
        "interestRate": { "type": "number", "description": "Interest rate" },
        "repaymentSchedule": { "type": "string", "description": "Repayment schedule (e.g., Monthly)" },
        "paidAmount": { "type": "number", "description": "Amount already repaid" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "repaying", "completed"], "description": "Loan status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Application timestamp" }
      },
      "required": ["id", "userId", "amount", "interestRate", "status"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "Deposit request",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique deposit ID" },
        "userId": { "type": "string", "description": "ID of the user" },
        "amount": { "type": "number", "description": "Deposit amount" },
        "method": { "type": "string", "description": "Deposit method" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Deposit status" },
        "proofImage": { "type": "string", "format": "uri", "description": "URL to proof of payment image" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Deposit timestamp" }
      },
      "required": ["id", "userId", "amount", "method", "status"]
    },
    "Beneficiary": {
      "title": "Beneficiary",
      "description": "Saved transfer beneficiary",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique beneficiary ID" },
        "userId": { "type": "string", "description": "ID of the user who saved this beneficiary" },
        "name": { "type": "string", "description": "Beneficiary name" },
        "accountNumber": { "type": "string", "description": "Beneficiary account number" },
        "bankName": { "type": "string", "description": "Beneficiary bank name" },
        "type": { "type": "string", "enum": ["internal", "local", "international"], "description": "Transfer type" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "userId", "name", "accountNumber", "type"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Administrative action log",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique log ID" },
        "adminId": { "type": "string", "description": "ID of the admin who performed the action" },
        "adminName": { "type": "string", "description": "Name of the admin" },
        "action": { "type": "string", "description": "Action performed" },
        "details": { "type": "string", "description": "Action details" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Action timestamp" }
      },
      "required": ["id", "adminId", "adminName", "action", "details"]
    },
    "PaymentMethod": {
      "title": "PaymentMethod",
      "description": "Bank payment method for deposits",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID" },
        "type": { "type": "string", "enum": ["bank", "crypto"], "description": "Method type" },
        "name": { "type": "string", "description": "Method name" },
        "details": { "type": "string", "description": "Account details" },
        "instructions": { "type": "string", "description": "Payment instructions" },
        "isActive": { "type": "boolean", "description": "Whether the method is active" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "type", "name", "details", "isActive"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "Message from contact form",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique message ID" },
        "name": { "type": "string", "description": "Sender name" },
        "email": { "type": "string", "format": "email", "description": "Sender email" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp" }
      },
      "required": ["id", "name", "email", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "Bank accounts collection"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions collection"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications collection"
    },
    "/chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Support chat messages collection"
    },
    "/loans/{loanId}": {
      "schema": "Loan",
      "description": "Loan applications collection"
    },
    "/deposits/{depositId}": {
      "schema": "Deposit",
      "description": "Deposit requests collection"
    },
    "/beneficiaries/{beneficiaryId}": {
      "schema": "Beneficiary",
      "description": "Saved beneficiaries collection"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Administrative audit logs collection"
    },
    "/payment_methods/{methodId}": {
      "schema": "PaymentMethod",
      "description": "Payment methods for deposits"
    },
    "/contact_messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Contact form messages"
    },
    "/settings/{settingId}": {
      "schema": "object",
      "description": "Global system settings"
    }
  }
}
